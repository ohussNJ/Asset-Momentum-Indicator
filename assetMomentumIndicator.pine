//@version=6
indicator("Asset Momentum Indicator", overlay=false)

// === Scoring Indicators ===
// Momentum (20 points): RSI (20)
// Trend (20): EMA/SMA (10), Ichimoku Cloud (10)
// Volatility(10): Realized Volatility 30D vs 90D (10)
// Volume(20): Net positive/negative volume (10), OBV (10)

// === Visual Indicators ===
// Short Term Momentum: Stochastic RSI
// Short Term Volume: Volume (Built in)

// === SCORE ===
buyScore = 0
sellScore = 0

// === VOLUME ===
volumeMALength = 20

volumeMA = ta.sma(volume, volumeMALength)

isVolumeIncreasing = volume > volume[1] and volume[1] > volume[2]
isVolumeDecreasing = volume < volume[1] and volume[1] < volume[2]

isStrongVolume = volume[2] > volumeMA and isVolumeIncreasing
isWeakVolume = volume[2] < volumeMA and isVolumeDecreasing

plotColor = isStrongVolume ? color.green : isWeakVolume ? color.red : color.blue

// === ALTERNATIVE VOLUME CONDITIONS (ratio-based, single bar) ===
// isStrongVolume = volume > volumeMA * 1.5
// isWeakVolume = volume < volumeMA * 0.6

// === OBV ===
obv = ta.obv
obvEMA = ta.ema(obv, 20)
obvSlope = ta.linreg(obv, 20, 0) - ta.linreg(obv, 20, 1)

if obv > obvEMA and obvSlope > 0
    buyScore += 10

if obv < obvEMA and obvSlope < 0
    sellScore += 10

// === NET POSITIVE/NEGATIVE VOLUME ===
nv = ta.change(close) > 0 ? volume : ta.change(close) < 0 ? -volume : 0
cnv = ta.cum(nv)
cnv_tb = cnv - ta.sma(cnv, 20) 

if cnv_tb > 0
    buyScore += 10
    
if cnv_tb < 0
    sellScore += 10

// === STOCH RSI ===
f_stochRSI(_rsiLength, _stochLength) =>
    r = ta.rsi(close, _rsiLength)
    s = ta.stoch(r, r, r, _stochLength)
    ta.sma(s, 3)

kSlow = f_stochRSI(14, 14)
kFast = f_stochRSI(6, 9) 

dSlow = ta.sma(kSlow, 3)
dFast = ta.sma(kFast, 3)

isStochOverSold = (kSlow < 20 and ta.crossover(kSlow, dSlow)) or (kFast < 20 and ta.crossover(kFast, dFast))
isStochOverBought = (kSlow > 80 and ta.crossunder(kSlow, dSlow)) or (kFast > 80 and ta.crossunder(kFast, dFast))

bgcolor(isStochOverSold ? color.new(color.green, 85) : na)
bgcolor(isStochOverBought ? color.new(color.red, 85) : na)

// === ICHIMOKU ===
donchian(len) => (ta.highest(high, len) + ta.lowest(low, len)) / 2

ichimokuConversionLine = donchian(9)
ichimokuBaseLine = donchian(26)
ichimokuLeadLine1 = (ichimokuConversionLine + ichimokuBaseLine) / 2
ichimokuLeadLine2 = donchian(52)

ichimokuSpanA = ichimokuLeadLine1[26]
ichimokuSpanB = ichimokuLeadLine2[26]

if close > ichimokuBaseLine
    buyScore += 5

if close < ichimokuBaseLine
    sellScore += 5

if close > ichimokuSpanA and close > ichimokuSpanB
    buyScore += 5

if close < ichimokuSpanA and close < ichimokuSpanB
    sellScore += 5

// === RSI === 
rsi = ta.rsi(close, 14)
rsiMA = ta.sma(rsi, 14)

rsiSmoothLen = 14
rsiTrendLen = 20

rsiSmooth = ta.ema(rsi, rsiSmoothLen)
rsiSlope = ta.linreg(rsiSmooth, rsiTrendLen, 0) - ta.linreg(rsiSmooth, rsiTrendLen, 1)

rsiConditions = (rsiSlope > 0 ? 1 : 0) + (rsi > 50 ? 1 : 0) + (rsi > rsiMA ? 1 : 0)
buyScore += rsiConditions >= 2 ? 20 : rsiConditions == 1 ? 10 : 0

rsiSellConditions = (rsiSlope < 0 ? 1 : 0) + (rsi < 50 ? 1 : 0) + (rsi < rsiMA ? 1 : 0)
sellScore += rsiSellConditions >= 2 ? 20 : rsiSellConditions == 1 ? 10 : 0

// === EMAs/SMAs ===
ema200 = ta.ema(close, 200)
ema50 = ta.ema(close, 50)

sma200 = ta.sma(close, 200)
sma50 = ta.sma(close, 50)

score50Buy = (close > ema50 ? 1 : 0) + (close > sma50 ? 1 : 0)
buyScore += score50Buy == 2 ? 5 : score50Buy == 1 ? 2 : 0

score200Buy = (close > ema200 ? 1 : 0) + (close > sma200 ? 1 : 0)
buyScore += score200Buy == 2 ? 5 : score200Buy == 1 ? 2 : 0

score50Sell = (close < ema50 ? 1 : 0) + (close < sma50 ? 1 : 0)
sellScore += score50Sell == 2 ? 5 : score50Sell == 1 ? 2 : 0

score200Sell = (close < ema200 ? 1 : 0) + (close < sma200 ? 1 : 0)
sellScore += score200Sell == 2 ? 5 : score200Sell == 1 ? 2 : 0

// === KELTNER (commented out, kept for reference) ===
// emaLength = input.int(20)
// atrLength = input.int(10)
// atrMult = input.float(2.0)
// widthSmoothing = input.int(10)
// emaMiddle = ta.ema(close, emaLength)
// atrValue = ta.atr(atrLength)
// upperBand = emaMiddle + atrMult * atrValue
// lowerBand = emaMiddle - atrMult * atrValue
// channelWidth = upperBand - lowerBand
// channelWidthSMA = ta.sma(channelWidth, widthSmoothing)
// keltnerChannelThreshold = 0.05 * channelWidthSMA
// isWidening = channelWidth > channelWidthSMA + keltnerChannelThreshold
// if close > upperBand and isWidening
//     buyScore += 10
// if close < lowerBand and isWidening
//     sellScore += 10

// === REALIZED VOLATILITY (30D vs 90D) ===
logReturn = math.log(close / close[1])
hv30 = ta.stdev(logReturn, 21) * math.sqrt(252) * 100
hv90 = ta.stdev(logReturn, 63) * math.sqrt(252) * 100

priceSlope = ta.linreg(close, 21, 0) - ta.linreg(close, 21, 1)
priceRising = priceSlope > 0
priceFalling = priceSlope < 0

if hv30 < hv90 and priceRising
    buyScore += 10

if hv30 > hv90 and priceFalling
    sellScore += 10

// === SIGNALS ===
netScore = buyScore - sellScore
scoreSMA5  = ta.sma(netScore, 5)
//scoreEMA8  = ta.ema(netScore, 8)
//scoreSMA10 = ta.sma(netScore, 10)

// === PLOTS ===
hline(0, "Neutral", color=color.gray, linestyle=hline.style_dotted, linewidth=2)
upperExtreme = hline(70, "Upper Band", color=color.new(color.red, 50), linestyle=hline.style_dashed)
lowerExtreme = hline(-70, "Lower Band", color=color.new(color.green, 50), linestyle=hline.style_dashed)
fill(upperExtreme, lowerExtreme, color=color.new(color.gray, 95))
plot(scoreSMA5,  title="Score SMA 5",  color=plotColor)
//plot(scoreEMA8,  title="Score EMA 8",  color=color.new(color.white, 30))
//plot(scoreSMA10, title="Score SMA 10", color=color.new(color.yellow, 30))
